# ===== Core =====
NODE_ENV=development
DATABASE_URL=file:./data/classaction.db
# Hosted libSQL/Turso databases usually require one of these tokens.
DATABASE_AUTH_TOKEN=
TURSO_AUTH_TOKEN=
TZ=America/New_York

# ===== Local development identity =====
# Local dev uses a seeded single-user profile. Hosted deployments use the Identity route gate.
SINGLE_USER_ID=1
SINGLE_USER_EMAIL=you@example.com
# Netlify hosted deploys enable the Identity route gate automatically.
# Set CLAIMBOT_REQUIRE_AUTH=true to exercise the gate locally.
CLAIMBOT_REQUIRE_AUTH=false
CLAIMBOT_DISABLE_AUTH=false
# Netlify sets NETLIFY=true automatically. Set this on other production hosts to
# enforce the same Content-Security-Policy headers.
CLAIMBOT_ENFORCE_CSP=false
# Required for hosted auth. Use a long random value and store it as a secret.
CLAIMBOT_SESSION_SECRET=
CLAIMBOT_DEV_SUBSCRIPTION_PLAN=
CLAIMBOT_DEV_SUBSCRIPTION_STATUS=

# ===== Scraper =====
# User-Agent identifies us honestly so site operators can contact / block.
SCRAPER_USER_AGENT="ClaimBot/0.1 (+https://yourdomain.com/contact)"
SCRAPER_RATE_LIMIT_MS=3000

# Public support address shown on /contact for clients and site operators.
# Leave blank locally; set a real monitored mailbox before inviting clients.
CLAIMBOT_SUPPORT_EMAIL=
# Optional hosted support link. Use this for a monitored Discord support server
# during beta when email support is not the primary path.
CLAIMBOT_SUPPORT_URL=

# ===== Claim Filer =====
# shadow = fills forms but stops before clicking submit (safe default)
# live = submits eligible authorized claims after preflight checks
CLAIM_FILER_MODE=shadow
# Required only when CLAIM_FILER_MODE=live in hosted deployment.
CLAIM_FILER_LIVE_ACK=
CLAIM_FILER_MAX_PER_DAY=20
# Optional worker proof helper. Set SMOKE_BASE_URL to a deployed ClaimBot preview
# and CLAIMBOT_WORKER_SMOKE_SEED=allow only when deliberately creating one
# synthetic due file_claim job for the hosted worker smoke.
SMOKE_BASE_URL=
CLAIMBOT_WORKER_SMOKE_FORM_URL=
CLAIMBOT_WORKER_SMOKE_SEED=

# ===== Discord webhook (notifications) =====
DISCORD_WEBHOOK_URL=

# ===== HIBP =====
HIBP_API_KEY=

# ===== Kimi / Moonshot design workflow =====
# Used by `npm run design:kimi` to ask Kimi for UI/product design direction.
KIMI_API_KEY=
# Alternative provider variable name accepted by the same script.
MOONSHOT_API_KEY=
# kimi-k2.6 is available, but may spend capped responses on reasoning.
# moonshot-v1-32k is recommended for visible design briefs.
KIMI_MODEL=moonshot-v1-32k
KIMI_MAX_TOKENS=2500
KIMI_TIMEOUT_MS=90000

# ===== Client feature flags =====
CLAIMBOT_FEATURE_SETTLEMENT_SEARCH=true
CLAIMBOT_FEATURE_BREACH_IMPORT=true
CLAIMBOT_FEATURE_LIVE_FILING=false

# ===== Billing checkout links =====
# Set true for beta launches where checkout is intentionally disabled.
CLAIMBOT_BETA_NO_BILLING=false
# Use Stripe Payment Links, Lemon Squeezy checkout links, or another hosted
# processor checkout URL. ClaimBot does not handle card data directly.
CLAIMBOT_BILLING_PLUS_MONTHLY_URL=
CLAIMBOT_BILLING_PLUS_YEARLY_URL=
CLAIMBOT_BILLING_PRO_MONTHLY_URL=
CLAIMBOT_BILLING_PRO_YEARLY_URL=
CLAIMBOT_BILLING_FOUNDING_URL=
# Long random value used to verify signed server-to-server billing sync events.
CLAIMBOT_BILLING_SYNC_SECRET=
# Optional Stripe webhook endpoint secret. If set, /api/billing/entitlement-sync
# can verify Stripe-Signature directly from Stripe webhooks.
CLAIMBOT_STRIPE_WEBHOOK_SECRET=

# ===== Captcha solver =====
CAPSOLVER_API_KEY=

# ===== Crypto =====
# 32-byte base64 key for libsodium secretbox (payment method encryption)
ENCRYPTION_KEY=
