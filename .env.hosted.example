# ClaimBot hosted launch template
# Copy values into Netlify or your secret manager for both production and
# deploy-preview contexts. Do not commit real values.

# Netlify project link. Prefer .netlify/state.json from `netlify link` locally.
# Use NETLIFY_SITE_ID/SITE_ID only in CI after confirming the site belongs to ClaimBot.
NETLIFY_SITE_ID=
SITE_ID=
# Optional operator dashboard shortcut for the in-app launch command bar.
NETLIFY_SITE_DASHBOARD_URL=
NETLIFY_SITE_SLUG=

# Persistent client data storage. Hosted deployments must not use file: URLs.
DATABASE_URL=libsql://YOUR_DATABASE.turso.io
DATABASE_AUTH_TOKEN=YOUR_DATABASE_TOKEN
TURSO_AUTH_TOKEN=

# Safe launch posture. Keep live filing disabled until client and legal review.
CLAIM_FILER_MODE=shadow
CLAIM_FILER_LIVE_ACK=
CLAIM_FILER_MAX_PER_DAY=20
# Paid full automation worker proof. The web app creates file_claim jobs;
# a persistent worker must process them automatically outside the request.
CLAIMBOT_WORKER_RUNTIME=scheduled-worker
CLAIMBOT_WORKER_RUNTIME_RECEIPT=
# Used by `npm run worker:file-claim:seed` to create one synthetic hosted
# file_claim job before worker smoke. Do not set the allow flag permanently.
SMOKE_BASE_URL=https://YOUR_PREVIEW.netlify.app
CLAIMBOT_WORKER_SMOKE_FORM_URL=
CLAIMBOT_WORKER_SMOKE_SEED=

# Public operator contacts for source operators and client support.
SCRAPER_USER_AGENT="ClaimBot/0.1 (+https://yourdomain.com/contact)"
CLAIMBOT_SUPPORT_EMAIL=support@yourdomain.com
# Optional beta support link, such as a monitored Discord invite.
CLAIMBOT_SUPPORT_URL=

# Hosted access and browser hardening.
CLAIMBOT_DISABLE_AUTH=false
CLAIMBOT_ENFORCE_CSP=true
CLAIMBOT_SESSION_SECRET=PASTE_GENERATED_SESSION_SECRET

# Launch compliance gate. Set to reviewed only after Terms, Privacy Policy,
# trust copy, proof handling, authorization gates, pricing, billing sync, and
# filing posture have been reviewed for the hosted deployment.
CLAIMBOT_LEGAL_REVIEW_ACK=

# Client capability flags. Keep live filing hidden for first hosted launch.
CLAIMBOT_FEATURE_SETTLEMENT_SEARCH=true
CLAIMBOT_FEATURE_BREACH_IMPORT=true
CLAIMBOT_FEATURE_LIVE_FILING=false

# Processor-hosted checkout links. Required before relying on paid plan CTAs.
# Set true for beta launches where checkout is intentionally disabled.
CLAIMBOT_BETA_NO_BILLING=false
CLAIMBOT_BILLING_PLUS_MONTHLY_URL=https://YOUR_PROCESSOR_CHECKOUT_LINK
CLAIMBOT_BILLING_PLUS_YEARLY_URL=
CLAIMBOT_BILLING_PRO_MONTHLY_URL=https://YOUR_PROCESSOR_CHECKOUT_LINK
CLAIMBOT_BILLING_PRO_YEARLY_URL=
CLAIMBOT_BILLING_FOUNDING_URL=
CLAIMBOT_BILLING_SYNC_SECRET=PASTE_GENERATED_BILLING_SYNC_SECRET
# Optional Stripe alternative. Use the endpoint secret if Stripe sends webhooks directly.
CLAIMBOT_STRIPE_WEBHOOK_SECRET=
