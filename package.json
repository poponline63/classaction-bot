{
  "name": "classaction-bot",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "description": "Personal tool that tracks class action settlements, matches against your eligibility profile, and queues authorized claims for preflight. Designed to scale into a multi-user SaaS.",
  "scripts": {
    "dev": "node scripts/start-dev-server.cjs",
    "build": "next build",
    "start": "next start -p 3100",
    "desktop:dev": "electron .",
    "desktop:install-browsers": "node scripts/install-playwright-browsers.cjs",
    "desktop:prepare": "node scripts/build-desktop.cjs && node scripts/prepare-desktop.cjs",
    "dist:win": "npm run desktop:install-browsers && npm run desktop:prepare && electron-builder --win portable",
    "lint": "next lint",
    "worker": "tsx worker/index.ts",
    "worker:dev": "tsx --watch worker/index.ts",
    "worker:once": "tsx worker/run-once.ts",
    "worker:file-claim:seed": "tsx scripts/seed-worker-file-claim-smoke.ts",
    "worker:file-claim:receipt": "tsx scripts/run-local-worker-file-claim-receipt.ts",
    "worker:github:doctor": "node scripts/github-worker-doctor.cjs",
    "scrape:once": "tsx scripts/scrape-once.ts",
    "scrape:strict": "tsx scripts/scrape-once.ts --strict",
    "enrich:source": "tsx scripts/enrich-source-catalog.ts",
    "source:export": "tsx scripts/export-source-catalog.ts",
    "source:import": "tsx scripts/import-source-catalog.ts",
    "source:import:dry": "tsx scripts/import-source-catalog.ts --dry-run",
    "source:packet": "tsx scripts/export-source-readiness-packet.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "validate:hosted": "tsx scripts/validate-hosted-env.ts --strict",
    "validate:schema": "tsx scripts/validate-database-schema.ts",
    "validate:source": "tsx scripts/validate-source-catalog.ts",
    "validate:source:strict": "tsx scripts/validate-source-catalog.ts --strict-quality",
    "validate:secrets": "node scripts/validate-secret-hygiene.cjs",
    "validate:routes": "node scripts/validate-next-route-exports.cjs",
    "validate:ui": "node scripts/validate-ui-guardrails.cjs",
    "validate:legal": "node scripts/validate-legal-readiness.cjs",
    "validate:pwa": "node scripts/validate-pwa.cjs",
    "validate:netlify": "node scripts/validate-netlify-preflight.cjs",
    "validate:netlify:strict": "node scripts/validate-netlify-preflight.cjs --strict",
    "netlify:doctor": "node scripts/netlify-launch-doctor.cjs",
    "netlify:doctor:strict": "node scripts/netlify-launch-doctor.cjs --strict",
    "netlify:record-setup": "tsx scripts/record-netlify-project-setup.ts",
    "hosted:checklist": "tsx scripts/hosted-setup-checklist.ts",
    "hosted:env:prepare": "node scripts/prepare-hosted-env.cjs",
    "hosted:env:doctor": "node scripts/push-hosted-env.cjs --check",
    "hosted:env:doctor:bootstrap": "node scripts/push-hosted-env.cjs --check --bootstrap",
    "hosted:env:push": "node scripts/push-hosted-env.cjs",
    "hosted:env:push:bootstrap": "node scripts/push-hosted-env.cjs --bootstrap",
    "hosted:db:prepare": "node scripts/prepare-hosted-database.cjs",
    "hosted:db:doctor": "node scripts/validate-hosted-database-env.cjs",
    "hosted:db:push": "node scripts/push-hosted-database.cjs",
    "hosted:db:packet": "tsx scripts/export-hosted-database-packet.ts",
    "hosted:db:receipt": "tsx scripts/run-hosted-database-receipt.ts",
    "operator:packet": "tsx scripts/export-operator-setup-packet.ts",
    "worker:packet": "tsx scripts/export-worker-runtime-packet.ts",
    "matcher:receipt": "tsx scripts/run-matcher-receipt.ts",
    "billing:packet": "tsx scripts/export-billing-activation-packet.ts",
    "billing:receipt": "tsx scripts/run-billing-sync-receipt.ts",
    "legal:packet": "tsx scripts/export-legal-review-packet.ts",
    "pwa:packet": "tsx scripts/export-pwa-readiness-packet.ts",
    "deploy:packet": "tsx scripts/export-deployability-packet.ts",
    "local:verify": "node scripts/export-local-verification-packet.cjs",
    "local:dev:doctor": "node scripts/check-local-dev-server.cjs",
    "local:dev:packet": "node scripts/export-local-dev-stability-packet.cjs",
    "responsive:packet": "node scripts/export-responsive-readiness-packet.cjs",
    "kimi:visual:packet": "node scripts/export-kimi-visual-readiness-packet.cjs",
    "automation:safety:packet": "tsx scripts/export-automation-safety-packet.ts",
    "audit:privacy:packet": "tsx scripts/export-audit-privacy-packet.ts",
    "audit:support:packet": "tsx scripts/export-audit-support-packet.ts",
    "activation:workbook": "tsx scripts/export-external-activation-workbook.ts",
    "client:checklist": "tsx scripts/export-client-preview-checklist.ts",
    "launch:handoff": "tsx scripts/export-launch-handoff.ts",
    "launch:refresh:packets": "node scripts/refresh-launch-packets.cjs",
    "launch:secrets": "node scripts/prepare-launch-secrets.cjs",
    "launch:push-secrets": "node scripts/push-launch-secrets.cjs",
    "with:hosted-env": "node scripts/run-with-hosted-env.cjs",
    "with:launch-secrets": "node scripts/run-with-launch-secrets.cjs",
    "build:hosted": "npm run validate:secrets && npm run validate:hosted && npm run validate:routes && npm run validate:ui && npm run validate:legal && npm run validate:pwa && npm run db:migrate && npm run validate:schema && npm run build",
    "preview:packet": "tsx scripts/export-preview-promotion-packet.ts",
    "preview:check-env": "node scripts/preview-promotion-gate.cjs --check-env-only",
    "preview:gate": "node scripts/preview-promotion-gate.cjs",
    "preview:gate:local": "node scripts/preview-promotion-gate.cjs --local",
    "production:check-receipt": "node scripts/validate-preview-promotion-receipt.cjs",
    "smoke:web": "node scripts/smoke-webapp.cjs",
    "smoke:auth": "node scripts/smoke-hosted-auth.cjs",
    "smoke:features": "node scripts/smoke-feature-flags.cjs",
    "smoke:hosted:local": "node scripts/smoke-hosted-local.cjs",
    "design:kimi": "node scripts/kimi-design-brief.mjs",
    "design:kimi:openclaw": "node scripts/kimi-openclaw-design-brief.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@netlify/identity": "^1.2.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^1.16.0",
    "next": "14.2.33",
    "node-cron": "^3.0.3",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.3",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.11",
    "@types/node": "^20.16.10",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.28.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "build": {
    "appId": "com.poponline63.classactionbot",
    "productName": "Class Action Bot",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "worker/**/*",
      "src/**/*",
      "scripts/**/*",
      "drizzle/**/*",
      "package.json",
      "tsconfig.json",
      "next.config.mjs",
      ".env.example",
      "node_modules/playwright-core/.local-browsers/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
